# --- Core bot/XUI settings (required) ---
TELEGRAM_BOT_TOKEN=
XUI_BASE_URL=https://panel.example.com/panel
XUI_USERNAME=admin
XUI_PASSWORD=
XUI_SERVER_HOST=127.0.0.1

# --- Webhook settings ---
WEBHOOK_BASE_URL=https://bot.example.com
WEBHOOK_PATH=telegram
WEBHOOK_LISTEN=0.0.0.0
WEBHOOK_PORT=8443
WEBHOOK_SECRET_TOKEN=

# --- Admin web panel ---
ADMIN_WEB_TOKEN=
ADMIN_WEB_SECRET=replace-with-long-random-secret
# For local docker-compose, keep this 8080 (host mapped separately).
ADMIN_WEB_PORT=8080

# --- Runtime/storage ---
BOT_DB_PATH=./data/bot.db
BOT_LOG_PATH=logs/bot.log

# --- Bot limits/tuning ---
# Telegram numeric admin ID (set your own).
ADMIN_TELEGRAM_ID=0
MAX_PLAN_DAYS=365
MAX_PLAN_GB=2000
MAX_BULK_COUNT=100
LOW_BALANCE_THRESHOLD=

# --- XUI request tuning ---
XUI_SUBSCRIPTION_PORT=2096
XUI_CONNECT_TIMEOUT=30
XUI_READ_TIMEOUT=30
XUI_REQUEST_RETRIES=2

# --- Referral/topup defaults ---
REFERRAL_COMMISSION_PCT=10
MANUAL_PAYMENT_DETAILS=Bank: Example Bank | Card: 0000-0000-0000-0000 | Name: Example

# --- install.sh / nginx / tls helper vars ---
PANEL_PORT=8080
BOT_PORT=8443
SSL_ENABLED=false
SSL_DOMAIN=example.com
SSL_INCLUDE_WWW=false
SSL_CERTBOT_MODE=standalone
SSL_CERT_PATH=/etc/letsencrypt/live/example.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/example.com/privkey.pem
LETSENCRYPT_EMAIL=admin@example.com
LETSENCRYPT_WEBROOT=/var/www/certbot

# --- set_webhook.sh retry tuning (optional) ---
WEBHOOK_HEALTH_RETRIES=10
WEBHOOK_HEALTH_RETRY_DELAY=3
WEBHOOK_SETUP_RETRIES=10
WEBHOOK_SETUP_RETRY_DELAY=3
